<article>
  <div class="post-header">
    <h1 class="post-title"><%= page.title %></h1>
    <div class="post-meta">
      <span><%= date(page.date, 'YYYY-MM-DD') %></span>
      <% if (page.categories && page.categories.length) { %>
      <span><%= page.categories.map(function(c){ return c.name; }).join(' / ') %></span>
      <% } %>
    </div>
  </div>

  <div class="post-content">
    <%- page.content %>
  </div>

  <!-- Tags -->
  <% if (page.tags && page.tags.length) { %>
  <div class="post-tags">
    <% page.tags.forEach(function(tag) { %>
    <a href="<%= url_for('/tags/' + tag.name + '/') %>"><%= tag.name %></a>
    <% }); %>
  </div>
  <% } %>
</article>

<!-- Post Navigation -->
<% if (page.prev || page.next) { %>
<nav class="post-nav">
  <% if (page.prev) { %>
  <div class="post-nav-item">
    <span class="nav-label">上一篇</span>
    <a href="<%= url_for(page.prev.path) %>"><span class="nav-title"><%= page.prev.title %></span></a>
  </div>
  <% } %>
  <% if (page.next) { %>
  <div class="post-nav-item">
    <span class="nav-label">下一篇</span>
    <a href="<%= url_for(page.next.path) %>"><span class="nav-title"><%= page.next.title %></span></a>
  </div>
  <% } %>
</nav>
<% } %>
