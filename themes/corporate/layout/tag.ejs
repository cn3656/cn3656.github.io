<section class="section">
  <div class="container">
    <% if (page.tag) { %>
    <h1 class="page-title-bar">标签：<%= page.tag %></h1>
    <div class="taxonomy-posts">
      <% (posts || []).forEach(function(post) { %>
      <article class="taxonomy-post">
        <time><%= date(post.date, 'YYYY-MM-DD') %></time>
        <a href="<%= url_for(post.permalink) %>"><%= post.title %></a>
      </article>
      <% }) %>
    </div>
    <% } else { %>
    <h1 class="page-title-bar">标签</h1>
    <div class="tag-cloud">
      <% (tags || []).forEach(function(tag) { %>
      <a href="<%= url_for('/tags/' + tag.name + '/') %>" class="tag-cloud-item">
        <span>#<%= tag.name %></span>
        <span class="tag-count"><%= tag.count %></span>
      </a>
      <% }) %>
    </div>
    <% } %>
  </div>
</section>
