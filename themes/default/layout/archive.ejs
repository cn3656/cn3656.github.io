<section class="archive">
  <h1 class="section-title">Archives</h1>
  <% archives.forEach(yearData => { %>
  <div class="archive-year">
    <h2 class="year-title"><%= yearData.year %> <small>(<%= yearData.count %>)</small></h2>
    <div class="year-posts">
      <% yearData.months.forEach(monthData => { %>
      <div class="archive-month">
        <h3 class="month-title"><%= monthData.month %>月</h3>
        <ul class="archive-list">
          <% monthData.posts.forEach(post => { %>
          <li>
            <time><%= date(post.date, 'MM-DD') %></time>
            <a href="<%= url_for(post.permalink) %>"><%= post.title %></a>
          </li>
          <% }) %>
        </ul>
      </div>
      <% }) %>
    </div>
  </div>
  <% }) %>
</section>
