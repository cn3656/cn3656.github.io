<section class="posts">
  <% posts.forEach((post, i) => { %>
  <article class="post-card animate-in">
    <div class="post-meta">
      <time datetime="<%= date(post.date, 'YYYY-MM-DD') %>"><%= date(post.date, 'YYYY-MM-DD') %></time>
      <% if (post.categories && post.categories.length) { %>
      <span class="post-category">
        <% post.categories.forEach(cat => { %>
        <a href="<%= url_for('/categories/' + cat + '/') %>"><%= cat %></a>
        <% }) %>
      </span>
      <% } %>
    </div>
    <h3 class="post-title">
      <a href="<%= url_for(post.permalink) %>"><%= post.title %></a>
    </h3>
    <div class="post-excerpt">
      <%- post.content %>
    </div>
    <% if (post.tags && post.tags.length) { %>
    <div class="post-tags">
      <% post.tags.forEach(tag => { %>
      <a href="<%= url_for('/tags/' + tag + '/') %>" class="tag">#<%= tag %></a>
      <% }) %>
    </div>
    <% } %>
    <a href="<%= url_for(post.permalink) %>" class="read-more">阅读全文</a>
  </article>
  <% }) %>
  
  <% if (pagination && pagination.totalPages > 1) { %>
  <nav class="pagination">
    <% if (pagination.hasPrev) { %>
    <a href="<%= pagination.prev === 1 ? url_for('/') : url_for('/page/' + pagination.prev + '/') %>" class="prev">&larr; 上一页</a>
    <% } %>
    <span class="page-info"><%= pagination.page %> / <%= pagination.totalPages %></span>
    <% if (pagination.hasNext) { %>
    <a href="<%= url_for('/page/' + pagination.next + '/') %>" class="next">下一页 &rarr;</a>
    <% } %>
  </nav>
  <% } %>
</section>
