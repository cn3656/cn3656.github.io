<!DOCTYPE html>
<html lang="<%= config.language || 'zh-CN' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= page.title %> - <%= config.title %>">
  <meta name="generator" content="Atom Blog">
  <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)">
  <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)">
  <title><% if (page.title) { %><%= page.title %> - <% } %><%= config.title %></title>
  <%- css('css/style') %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="alternate" href="/atom.xml" title="<%= config.title %>" type="application/atom+xml">
  <% if (config.seo && config.seo.google_analytics) { %>
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= config.seo.google_analytics %>"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag('js',new Date());gtag('config','<%= config.seo.google_analytics %>');</script>
  <% } %>
</head>
<body>
  <header class="header">
    <div class="container">
      <div class="header-left">
        <h1 class="logo"><a href="<%= url_for('/') %>"><%= config.title %></a></h1>
        <nav class="nav">
          <% Object.entries(config.menu || {}).forEach(([name, url]) => { %>
          <a href="<%= url_for(url) %>" class="nav-link"><%= name %></a>
          <% }) %>
        </nav>
      </div>
    </div>
  </header>
  
  <main class="main">
    <div class="container">
      <%- body %>
    </div>
  </main>
  
  <footer class="footer">
    <div class="container">
      <p>&copy; <%= new Date().getFullYear() %> <%= config.author || config.title %>. 由 <a href="https://github.com/cn3656/atom" target="_blank" rel="noopener">Atom</a> 驱动</p>
      <% if (config.social) { %>
      <div class="social">
        <% Object.entries(config.social).forEach(([name, url]) => { %>
        <a href="<%= url %>" target="_blank" rel="noopener noreferrer"><%= name %></a>
        <% }) %>
      </div>
      <% } %>
    </div>
  </footer>
  
  <button class="back-top" aria-label="回到顶部">&uarr;</button>
  <%- js('js/main') %>
</body>
</html>
