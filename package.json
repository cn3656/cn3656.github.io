{
  "name": "atom-blog",
  "version": "1.0.0",
  "description": "A lightweight, Hexo-compatible static blog generator with pluggable themes and multi-platform deployment",
  "main": "lib/index.js",
  "bin": {
    "atom": "bin/atom.js"
  },
  "scripts": {
    "init": "node bin/atom.js init",
    "generate": "node bin/atom.js generate",
    "server": "node bin/atom.js server",
    "deploy": "node bin/atom.js deploy",
    "clean": "node bin/atom.js clean",
    "new": "node bin/atom.js new",
    "dev": "node bin/atom.js server --watch"
  },
  "keywords": [
    "blog",
    "static-site",
    "hexo-compatible",
    "github-pages",
    "cloudflare"
  ],
  "author": "atom",
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "connect": "^3.7.0",
    "ejs": "^3.1.10",
    "gray-matter": "^4.0.3",
    "hexo-abbrlink": "^2.2.1",
    "hexo-generator-searchdb": "^1.5.0",
    "hexo-util": "^4.0.0",
    "hexo-wordcount": "^6.0.1",
    "highlight.js": "^11.9.0",
    "js-yaml": "^4.1.0",
    "marked": "^12.0.1",
    "open": "^10.1.0",
    "serve-static": "^1.15.0"
  }
}
